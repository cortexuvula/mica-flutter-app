  "memoryShortVerbalTitle": "Short Verbal Memory Test",
  "memoryShortVerbalPatientInstruction1": "\"I would like you to remember a name and address. Listen carefully as I will say it only once. Are you ready?\"",
  "memoryShortVerbalPatientInstruction2": "\"Peter Black, 25 Market Close, Northam, Wheatbelt. Can you repeat that?\"",
  "memoryShortVerbalPatientReminder": "\"Remember the name and address as I will ask for it later.\"",
  "memoryShortVerbalDelayedInstruction": "\"Tell me the name and address that you learned earlier.\"",
  "memoryShortVerbalCuedInstruction": "\"Did I ask you to remember...?\"",
  "memoryShortVerbalTapWordsInstruction": "Tap on words correctly recalled.",
  "memoryShortVerbalRepeatInstruction": "If the patient is able to recall without error then continue. If unable, then the name and address can be repeated up to 3 times asking for recall each time. This is not scored.",
  "memoryShortVerbalDistractionInstruction": "Allow about 5 minutes to pass by using distraction",
  "memoryShortVerbalCuedExaminerInstruction": "Test for cued recall by giving alternatives as indicated below.",
  "memoryShortVerbalCuedTapInstruction": "Read 2 alternatives and target word.\nTap on words correctly recalled.",
  "memoryShortVerbalRecognitionMemoryTitle": "Name and Address: Recognition Memory",
